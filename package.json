{
  "name": "awapi-editor",
  "version": "2.3.1",
  "description": "A fast, lightweight, universal text editor",
  "main": "dist/main/main.js",
  "scripts": {
    "test": "vitest run",
    "dev": "vite",
    "build": "cross-env NODE_ENV=production vite build",
    "package": "cross-env NODE_ENV=production vite build && electron-builder",
    "release": "cross-env NODE_ENV=production vite build && electron-builder --publish always",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "icons": "node scripts/generate-icons.js"
  },
  "build": {
    "appId": "com.awapi.awapieditor",
    "publish": [
      "github"
    ],
    "productName": "AwapiEditor",
    "directories": {
      "output": "release"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon-512x512.png",
      "category": "Utility",
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "deb": {
      "maintainer": "awapi <oyesil@gmail.com>"
    },
    "files": [
      "dist/**/*",
      "build/**/*"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/awapi/awapi-editor.git"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/awapi/awapi-editor/issues"
  },
  "homepage": "https://github.com/awapi/awapi-editor#readme",
  "overrides": {
    "dompurify": "^3.4.1"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.2",
    "png2icons": "^2.0.1",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.5"
  }
}
